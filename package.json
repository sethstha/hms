{
  "name": "hms",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:org": "pnpm --filter @hms/org dev",
    "dev:admin": "pnpm --filter @hms/admin dev",
    "dev:api": "pnpm --filter @hms/api dev",
    "db:seed": "pnpm --filter @hms/db db:seed",
    "db:generate": "pnpm --filter @hms/db db:generate",
    "db:migrate": "pnpm --filter @hms/db db:migrate",
    "check": "pnpm -r --parallel check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:packages": "pnpm -r --parallel lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sync:vars": "node scripts/sync-dev-vars.js",
    "release": "node scripts/release.js",
    "release:hospital": "pnpm --filter @hms/hospital release",
    "release:admin": "pnpm --filter @hms/admin release",
    "release:api": "pnpm --filter @hms/api release"
  },
  "devDependencies": {
    "@clack/prompts": "^1.2.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "concurrently": "9.2.1",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-svelte": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "svelte": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "^6.0.2",
    "typescript-eslint": "catalog:",
    "zx": "^8.8.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
