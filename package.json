{
  "name": "hms",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:hospital": "pnpm --filter hospital dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:api": "pnpm --filter api dev",
    "db:seed": "pnpm --filter @hms/db db:seed",
    "build:admin": "pnpm --filter admin build",
    "build:hospital": "pnpm --filter hospital build",
    "build:api": "pnpm --filter api deploy",
    "db:generate": "pnpm --filter @hms/db db:generate",
    "db:migrate": "pnpm --filter @hms/db db:migrate",
    "check": "pnpm -r --parallel check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:packages": "pnpm -r --parallel lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "pnpm check"
  },
  "devDependencies": {
    "@clack/prompts": "^1.2.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "concurrently": "9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "5.54.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "zx": "^8.8.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
