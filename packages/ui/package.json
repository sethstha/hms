{
  "name": "@hms/ui",
  "version": "0.0.1",
  "private": true,
  "svelte": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./src/styles.css",
    "./utils": {
      "types": "./src/utils.ts",
      "default": "./src/utils.ts"
    },
    "./components/ui/*": {
      "types": "./src/components/ui/*/index.ts",
      "svelte": "./src/components/ui/*/index.ts",
      "default": "./src/components/ui/*/index.ts"
    }
  },
  "dependencies": {
    "@hms/utils": "workspace:*",
    "@lucide/svelte": "^1.7.0",
    "bits-ui": "^2.16.5",
    "mode-watcher": "^1.1.0",
    "svelte-sonner": "^1.1.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-svelte-plugin": "^0.3.51"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  }
}
