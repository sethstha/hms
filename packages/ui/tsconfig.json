{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["svelte"],
    "plugins": [
      {
        "name": "typescript-svelte-plugin",
        "assumeIsSvelteProject": true,
        "disableSvelteProjectDetection": true,
      },
    ],
  },

  "include": ["src/**/*.ts", "src/**/*.svelte"],
}
